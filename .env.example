# Frontend Environment Configuration
# Copy this file to .env.local and update values

# Backend API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Application Name
NEXT_PUBLIC_APP_NAME=System LLM

# Sentry error monitoring (DSN is public — safe to expose in the browser bundle)
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source-map upload during build (CI/Vercel only, NOT public — keep secret)
# SENTRY_AUTH_TOKEN=
